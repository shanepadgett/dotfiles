#!/bin/bash
# Central configuration for installation paths
# This file should be sourced by all scripts

# Installation directory - change this single value to change where everything is installed
INSTALL_DIR="$HOME/.dotfiles"

# Derived paths
CONFIG_SHELL_DIR="$INSTALL_DIR/config/shell"
CONFIG_TOOLS_DIR="$INSTALL_DIR/config/tools"
SCRIPTS_DIR="$INSTALL_DIR/scripts"