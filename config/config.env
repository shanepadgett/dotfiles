#!/bin/zsh
# Central configuration for installation paths
# This file should be sourced by all scripts

# Detect environment and set installation directory dynamically
# Dev containers mount the repo at /workspaces/dotfiles
# Host machines clone the repo to ~/.dotfiles
if [[ -d "/workspaces" ]] || [[ -n "${REMOTE_CONTAINERS:-}" ]] || [[ -n "${CODESPACES:-}" ]] || [[ -n "${DEVCONTAINER:-}" ]] || [[ -f "/.dockerenv" ]]; then
    # Dev container environment
    INSTALL_DIR="/workspaces/dotfiles"
else
    # Host machine environment
    INSTALL_DIR="$HOME/.dotfiles"
fi

# Derived paths
CONFIG_SHELL_DIR="$INSTALL_DIR/config/shell"
CONFIG_TOOLS_DIR="$INSTALL_DIR/config/tools"
SCRIPTS_DIR="$INSTALL_DIR/scripts"